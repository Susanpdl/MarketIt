# Database
DATABASE_URL="postgresql://user:password@localhost:5432/marketit"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# CORS (allowed client origin)
CLIENT_URL="http://localhost:3000"

# API (for client)
NEXT_PUBLIC_API_URL="http://localhost:3001"

# n8n integration (optional - add to server/.env)
# N8N_WEBHOOK_URL="https://your-n8n.com/webhook/influencer-created"
# N8N_WEBHOOK_SECRET="your-secret-for-n8n-callbacks"
