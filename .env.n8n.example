# Used by: docker compose -f docker-compose.n8n.yml --env-file .env.n8n up -d
#
# N8N_PUBLIC_HOST = subdomain for n8n UI + webhook base (no https://)
#   Example: n8n.yourdomain.com
#
# Use a strong password; this protects the n8n editor and workflow UI.

N8N_PUBLIC_HOST=n8n.yourdomain.com
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-this-to-a-long-random-password
